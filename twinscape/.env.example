# Twinscape — template env. Salin ke `.env` lalu isi:
#   cp twinscape/.env.example twinscape/.env
# Dibaca otomatis saat `npm start`. TIDAK di-commit (.gitignore).

# ── Remote ────────────────────────────────────────────────────────
# .env cukup jadi SAKELAR. SEMUA target & kredensial SSH/VNC ada di twinscape/remotes.json
# (host, port, username, password/keyFile, roles). Lihat twinscape/remotes.example.json.
REMOTE_ENABLE=0                       # 1 = aktifkan fitur remote (tombol Open SSH/VNC); 0 = mati

# (opsional) mode 1-device tanpa remotes.json — kalau tak pakai remotes.json:
# REMOTE_SSH_HOST=
# REMOTE_SSH_USER=
# REMOTE_SSH_PASSWORD=

# ── Opsional lain ─────────────────────────────────────────────────
# V2_PORT=10102
# V2_HOST=127.0.0.1                   # bind localhost saja; hapus = akses dari LAN
# PULSE_SECRET=                       # kunci sesi login; kosong = auto ke twinscape/.pulse-secret
