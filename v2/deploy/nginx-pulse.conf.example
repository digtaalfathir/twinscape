# =====================================================================
# Stechoq Pulse (monitoring v2) — reverse proxy nginx
# Domain  →  127.0.0.1:10102 (proses PM2 "stechoq-pulse")
#
# Pasang:
#   sudo cp v2/deploy/nginx-pulse.conf.example /etc/nginx/sites-available/pulse.conf
#   sudo nano /etc/nginx/sites-available/pulse.conf     # ganti server_name
#   sudo ln -s /etc/nginx/sites-available/pulse.conf /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# TLS (HTTPS) otomatis:
#   sudo certbot --nginx -d pulse.contoh.com            # menambah blok 443 + redirect 80→443
# =====================================================================

# WebSocket upgrade. Kalau blok "map" ini bentrok (sudah ada di nginx.conf),
# pindahkan ke http{} di /etc/nginx/nginx.conf dan hapus dari sini.
map $http_upgrade $connection_upgrade { default upgrade; '' close; }

server {
    listen 80;
    server_name pulse.contoh.com;      # ← GANTI dengan domain kamu

    # halaman + aset statik (index.html, floormap.html, js, css, models, vendor)
    location / {
        proxy_pass http://127.0.0.1:10102;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # status live (/ws?loc=...) — WAJIB header upgrade, kalau tidak WS gagal connect
    location /ws {
        proxy_pass http://127.0.0.1:10102;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host       $host;
        proxy_read_timeout 3600s;      # jaga koneksi WS lama tetap hidup
    }
}
