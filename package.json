{
  "name": "twinscape",
  "version": "2.0.0",
  "description": "Live 2D/3D digital twin to monitor and remote-control (SSH/VNC) your infrastructure.",
  "main": "twinscape/server.js",
  "scripts": {
    "start": "node twinscape/server.js",
    "dev": "node twinscape/server.js",
    "twinscape": "node twinscape/server.js",
    "agent": "node legacy/agent.js",
    "builder": "node builder/server.js",
    "classic": "node legacy/src/app.js",
    "up": "pm2 start ecosystem.config.js",
    "up:logs": "pm2 logs",
    "up:stop": "pm2 stop ecosystem.config.js",
    "agent:start": "pm2 start ecosystem.config.js --only twinscape-agent",
    "agent:logs": "pm2 logs twinscape-agent",
    "pulse:start": "pm2 start ecosystem.config.js --only twinscape",
    "pulse:restart": "pm2 restart twinscape",
    "pulse:stop": "pm2 stop twinscape",
    "pulse:logs": "pm2 logs twinscape",
    "classic:start": "pm2 start legacy/ecosystem.config.js",
    "classic:restart": "pm2 restart hardware-monitoring",
    "classic:stop": "pm2 stop hardware-monitoring",
    "classic:logs": "pm2 logs hardware-monitoring"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ping": "^0.4.4",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "author": "Rifky Andigta Al-Fathir",
  "license": "MIT"
}
