{
  "name": "twinscape",
  "version": "2.0.0",
  "description": "Web monitoring dashboard with live 2D/3D visualization.",
  "main": "twinscape/server.js",
  "scripts": {
    "start": "node twinscape/server.js",
    "dev": "node twinscape/server.js",
    "twinscape": "node twinscape/server.js",
    "builder": "node builder/server.js",
    "classic": "node legacy/src/app.js",
    "pulse:start": "pm2 start twinscape/ecosystem.config.js",
    "pulse:restart": "pm2 restart twinscape-v2",
    "pulse:stop": "pm2 stop twinscape-v2",
    "pulse:logs": "pm2 logs twinscape-v2",
    "classic:start": "pm2 start legacy/ecosystem.config.js",
    "classic:restart": "pm2 restart hardware-monitoring",
    "classic:stop": "pm2 stop hardware-monitoring",
    "classic:logs": "pm2 logs hardware-monitoring"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ping": "^0.4.4",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "author": "Rifky Andigta Al-Fathir",
